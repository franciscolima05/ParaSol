{
  "info": {
    "name": "ParaSol Backend",
    "description": "Endpoints geoespaciales de ParaSol: lluvia (CHIRPS), TWI (SRTM) y anegamiento (Sentinel-1 SAR).\n\nVariables:\n- baseUrl: URL del backend FastAPI (default http://localhost:8000)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "a4f3c8b1-2d6e-4a7f-9b1c-parasol000001"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        }
      },
      "response": []
    },
    {
      "name": "Rainfall check — CHIRPS (Tres Arroyos 2025)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"coordinates\": [\n    [-60.326698, -38.198767],\n    [-60.306698, -38.198767],\n    [-60.306698, -38.178767],\n    [-60.326698, -38.178767],\n    [-60.326698, -38.198767]\n  ],\n  \"start_date\": \"2025-01-01\",\n  \"end_date\": \"2025-12-31\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/rainfall/check",
          "host": ["{{baseUrl}}"],
          "path": ["rainfall", "check"]
        },
        "description": "Lluvia acumulada y serie diaria CHIRPS sobre un polígono ~2×2 km cerca de Tres Arroyos (sur BsAs), año calendario 2025 completo. Devuelve total_rainfall_mm, unit, period y series[365]."
      },
      "response": []
    },
    {
      "name": "Rainfall check — CHIRPS (Salado 2017)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"coordinates\": [\n    [\n      [-60.20, -35.48],\n      [-60.13, -35.48],\n      [-60.13, -35.42],\n      [-60.20, -35.42],\n      [-60.20, -35.48]\n    ]\n  ],\n  \"start_date\": \"2016-11-01\",\n  \"end_date\": \"2017-03-31\"\n}"
